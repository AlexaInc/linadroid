# =====================================================================
# LinaDroid OS - Custom Linux Kernel Configuration Fragment
# Designed for Linux Kernel 6.1 / 6.6 LTS
# Merges standard GNU/Linux features (Systemd, Docker) with Android
# =====================================================================

# --- General System Configuration ---
CONFIG_LOCALVERSION="-linadroid"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_AUDIT=y

# --- Android IPC & Core Drivers ---
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_BINDER_IPC_SELFTEST=y

# --- Memory Management ---
# Modern kernels deprecate ashmem in favor of memfd, but let's keep both
# to support older Android blobs.
CONFIG_ASHMEM=y
CONFIG_MEMFD_CREATE=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_ANON_INODES=y

# --- Namespaces (Essential for LXC and Docker) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# --- Control Groups (Cgroups v2 & v1 Support) ---
CONFIG_CGROUPS=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_SOCK_CGROUP_DATA=y

# --- Filesystem Configs ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y
CONFIG_BTRFS_FS=y

# --- Network & Container Virtualization ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_BRIDGE=y
CONFIG_NET_CORE=y
CONFIG_VETH=y
CONFIG_MACVLAN=y
CONFIG_IPVLAN=y
CONFIG_TUN=y
CONFIG_TAP=y
CONFIG_IP_SET=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NF_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP_NF_NAT=y

# --- Input Devices ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_MISC=y

# --- Graphics & Direct Rendering Manager (DRM) ---
# This is crucial! SurfaceFlinger needs direct access to these.
CONFIG_DRM=y
CONFIG_DRM_MIPI_DSI=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=100
CONFIG_DRM_SIMPLE_DRM=y

# Enable GPU drivers for targets (e.g. Intel, AMD, VirtIO for VMs, Panfrost for ARM)
CONFIG_DRM_I915=m
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_NOUVEAU=m
CONFIG_DRM_VIRTIO_GPU=m
CONFIG_DRM_PANFROST=m
CONFIG_DRM_LIMA=m

# --- Sound (ALSA) ---
CONFIG_SND=y
CONFIG_SND_HRTIMER=y
CONFIG_SND_PORTMAN=y
CONFIG_SND_USB_AUDIO=y

# --- Power & Performance ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_PM=y
CONFIG_SUSPEND=y
